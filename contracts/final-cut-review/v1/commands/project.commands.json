{
  "contract_version": "1.0",
  "commands": [
    {
      "command_type": "CreateProject",
      "capability": "review.project.create",
      "idempotent": true,
      "payload_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["project_code", "project_name"],
        "properties": {
          "project_code": {"type": "string", "minLength": 1, "maxLength": 128},
          "project_name": {"type": "string", "minLength": 1, "maxLength": 255},
          "description": {"type": "string", "maxLength": 2000},
          "external_project_id": {"type": "string", "minLength": 1, "maxLength": 128}
        }
      }
    },
    {
      "command_type": "UpdateProject",
      "capability": "review.project.update",
      "idempotent": false,
      "payload_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["project_ref_id", "project_name", "description"],
        "properties": {
          "project_ref_id": {"type": "string", "minLength": 1},
          "project_name": {"type": "string", "minLength": 1, "maxLength": 255},
          "description": {"type": "string", "maxLength": 2000}
        }
      }
    },
    {
      "command_type": "ArchiveProject",
      "capability": "review.project.archive",
      "idempotent": false,
      "payload_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["project_ref_id"],
        "properties": {
          "project_ref_id": {"type": "string", "minLength": 1}
        }
      }
    },
    {
      "command_type": "RestoreProject",
      "capability": "review.project.restore",
      "idempotent": false,
      "payload_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["project_ref_id"],
        "properties": {
          "project_ref_id": {"type": "string", "minLength": 1}
        }
      }
    },
    {
      "command_type": "SoftDeleteProject",
      "capability": "review.project.delete",
      "idempotent": false,
      "payload_schema": {
        "type": "object",
        "additionalProperties": false,
        "required": ["project_ref_id", "confirmed"],
        "properties": {
          "project_ref_id": {"type": "string", "minLength": 1},
          "confirmed": {"type": "boolean", "const": true}
        }
      }
    }
  ]
}
