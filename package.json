{
  "name": "fj-final-cut-review",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "engines": {
    "node": "^22.13.0 || ^24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5188 --strictPort",
    "build": "tsc -b && vite build && node scripts/verify-frontend-security-headers.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "security:frontend-headers": "node scripts/verify-frontend-security-headers.mjs",
    "contracts:generate": "node scripts/contracts-check.mjs --generate",
    "contracts:check": "node scripts/contracts-check.mjs",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:integration": "playwright test --config=playwright.integration.config.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.12",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.68.0",
    "react-router-dom": "^7.11.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.3.6",
    "vitest": "^4.0.16"
  }
}
