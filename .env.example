# Copy to .env and configure local-only secret file paths. Do not commit .env
# or any file below .env.secrets/. Compose requires five non-empty, one-line
# UTF-8 files; keep them regular, non-symlink, and mode 0600 on the host.
COMPOSE_POSTGRES_ADMIN_PASSWORD_FILE=.env.secrets/postgres-admin-password
COMPOSE_POSTGRES_OWNER_PASSWORD_FILE=.env.secrets/postgres-owner-password
COMPOSE_POSTGRES_APP_PASSWORD_FILE=.env.secrets/postgres-app-password
COMPOSE_WRITE_GUARD_CODE_FILE=.env.secrets/write-guard-code
COMPOSE_WRITE_GUARD_SESSION_SECRET_FILE=.env.secrets/write-guard-session-secret

# Direct values remain available only for explicit host/Homebrew workflows.
# Leave the matching *_FILE unset, or leave these direct values empty, because
# application and migration readers reject ambiguous dual configuration.
POSTGRES_ADMIN_DB=postgres
POSTGRES_ADMIN_USER=postgres
POSTGRES_ADMIN_PASSWORD=
POSTGRES_ADMIN_PASSWORD_FILE=
POSTGRES_OWNER_USER=final_cut_review_owner
POSTGRES_OWNER_PASSWORD=
POSTGRES_OWNER_PASSWORD_FILE=
POSTGRES_APP_DB=final_cut_review
POSTGRES_APP_USER=final_cut_review_app
POSTGRES_APP_PASSWORD=
POSTGRES_APP_PASSWORD_FILE=
POSTGRES_TEST_DB=final_cut_review_test
POSTGRES_HOST_PORT=5432
BACKEND_HOST_PORT=8000
# Stable engine-level volume names. On first upgrade from a custom legacy
# Compose project, set these to <old-project>_fj-final-cut-review-*.
POSTGRES_VOLUME_NAME=fj-final-cut-review_fj-final-cut-review-postgres
DATA_VOLUME_NAME=fj-final-cut-review_fj-final-cut-review-data
RUNTIME_STATE_VOLUME_NAME=fj-final-cut-review_fj-final-cut-review-runtime-state
# Mutable local build tag used only by docker-compose.yml build workflows.
BACKEND_IMAGE=fj-final-cut-review-backend:local
# Required by docker-compose.delivery.yml. The overlay constructs exactly
# <repository>@sha256:<64-lowercase-hex>; the delivery wrapper rejects mutable tags.
BACKEND_IMAGE_REPOSITORY=fj-final-cut-review-backend
BACKEND_IMAGE_DIGEST=
DATABASE_CONNECT_TIMEOUT_SECONDS=5
DATABASE_STATEMENT_TIMEOUT_MS=30000
DATABASE_MIGRATION_STATEMENT_TIMEOUT_MS=300000
MAINTENANCE_INTERVAL_SECONDS=300
MAINTENANCE_CYCLE_TIMEOUT_SECONDS=60
MAINTENANCE_MAX_CONSECUTIVE_ERRORS=3
MAINTENANCE_HEALTH_MAX_AGE_SECONDS=420
# Set to 1 only for a controlled restore/upgrade that may introduce legacy file ownership.
FORCE_DATA_OWNERSHIP_MIGRATION=0
# Direct host-process DSN is optional. If used, URI-reserved password characters
# must be percent-encoded. Compose uses the component fields below instead.
# PostgreSQL hard gates require all three distinct URLs. DATABASE_URL is the
# runtime role on the disposable test database; owner/admin URLs never enter
# backend, maintenance, or package-worker runtime environments.
DATABASE_URL=
DATABASE_URL_FILE=
POSTGRES_OWNER_DATABASE_URL=
POSTGRES_ADMIN_DATABASE_URL=
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=final_cut_review
DATABASE_USER=final_cut_review_app
DATABASE_PASSWORD=
DATABASE_PASSWORD_FILE=
STORAGE_ROOT=backend/.data/storage
PACKAGE_ROOT=backend/.data/packages
MAX_UPLOAD_BYTES=5368709120
MAX_UPLOAD_PARTS=256
# Must exceed UPLOAD_PART_READ_TIMEOUT_SECONDS by at least 60 seconds.
UPLOAD_SESSION_TTL_SECONDS=900
# Total wall-clock budget for request-body read, write, flush, and fsync.
UPLOAD_PART_READ_TIMEOUT_SECONDS=120
UPLOAD_PART_IO_WORKERS=4
MAX_INFLIGHT_UPLOAD_PARTS_PER_PRINCIPAL=80
MAX_INFLIGHT_UPLOAD_PARTS_PER_SESSION=1
MAX_INFLIGHT_UPLOAD_PART_CANDIDATES=128
MAX_ACTIVE_UPLOAD_SESSIONS_GLOBAL=128
MAX_ACTIVE_UPLOAD_SESSIONS_PER_PRINCIPAL=80
MAX_RESERVED_UPLOAD_BYTES_GLOBAL=1099511627776
MAX_RESERVED_UPLOAD_BYTES_PER_PRINCIPAL=1099511627776
UPLOAD_STORAGE_LOW_WATERMARK_BYTES=1073741824
UPLOAD_FINALIZATION_LEASE_SECONDS=7200
# Process-local upload admission requires one Uvicorn worker and one backend replica.
UPLOAD_RUNTIME_WORKER_COUNT=1
MAX_PACKAGE_FILES=100
MAX_PACKAGE_BYTES=5368709120
MAX_PENDING_PACKAGE_BUILDS=8
MAX_PACKAGE_STORAGE_BYTES=21474836480
PACKAGE_TTL_SECONDS=86400
PACKAGE_DOWNLOAD_SESSION_TTL_SECONDS=120
PACKAGE_DOWNLOAD_LEASE_SECONDS=7200
PACKAGE_DOWNLOAD_COOLDOWN_SECONDS=10
PACKAGE_WORKER_INTERVAL_SECONDS=2
PACKAGE_WORKER_CYCLE_TIMEOUT_SECONDS=7200
PACKAGE_WORKER_HEALTH_MAX_AGE_SECONDS=90
PACKAGE_WORKER_MAX_ATTEMPTS=3
PACKAGE_WORKER_RETRY_DELAY_SECONDS=30
DATA_OWNERSHIP_LOCK_TIMEOUT_SECONDS=120
DATA_OWNERSHIP_LOCK_STALE_SECONDS=30
WRITE_GUARD_MODE=reverse_proxy
WRITE_GUARD_CODE=
WRITE_GUARD_CODE_FILE=
# Generate with: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
WRITE_GUARD_SESSION_SECRET=
WRITE_GUARD_SESSION_SECRET_FILE=
WRITE_GUARD_SESSION_TTL_SECONDS=14400
REVERSE_PROXY_WRITE_HEADER=x-write-guard-verified
# Exact source address seen by the backend. A proxy running on the Docker host
# normally reaches the container from the Compose network gateway, not 127.0.0.1.
REVERSE_PROXY_TRUSTED_HOSTS=
BROWSER_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5175,http://localhost:5175
LOG_LEVEL=INFO

# Frontend standalone/runtime integration. The principal context must be a
# backend-signed, host-issued value injected by a trusted local proxy or host.
VITE_FINAL_CUT_REVIEW_API_BASE_URL=http://127.0.0.1:8000
# Optional local Playwright channel. Use chrome to reuse an installed Chrome
# when the matching bundled Chromium cache is unavailable.
FCR_PLAYWRIGHT_CHANNEL=
